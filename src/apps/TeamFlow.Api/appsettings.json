{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "TeamFlow",
    "Audience": "TeamFlow.Users",
    "Secret": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "RateLimiting": {
    "AuthPermitLimit": 30,
    "AuthWindowSeconds": 60,
    "WritePermitLimit": 60,
    "WriteWindowSeconds": 60,
    "SearchPermitLimit": 40,
    "SearchWindowSeconds": 60,
    "BulkPermitLimit": 10,
    "BulkWindowSeconds": 60,
    "GeneralPermitLimit": 200,
    "GeneralWindowSeconds": 60,
    "SegmentsPerWindow": 4,
    "QueueLimit": 0
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "",
    "Password": "",
    "VirtualHost": "/"
  }
}
