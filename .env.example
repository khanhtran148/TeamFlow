# TeamFlow Environment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to version control
#
# Required for: docker-compose.yml, docker-compose.prod.yml

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=teamflow
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=changeme

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=teamflow
RABBITMQ_DEFAULT_PASS=changeme

# ─── JWT Authentication ─────────────────────────────────────────────────────
JWT_ISSUER=TeamFlow
JWT_AUDIENCE=TeamFlow.Users
JWT_SECRET=changeme-minimum-32-characters-long-secret-key

# ─── Connection Strings ─────────────────────────────────────────────────────
# Used by API and Background Services when running outside Docker
CONNECTION_STRING=Host=localhost;Database=teamflow;Username=teamflow;Password=changeme

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── ASP.NET Core ────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://+:8080

# ─── Logging ─────────────────────────────────────────────────────────────────
# Override log levels per namespace (optional)
# Logging__LogLevel__Default=Information
# Logging__LogLevel__Microsoft.AspNetCore=Warning

# ─── Rate Limiting (optional overrides) ─────────────────────────────────────
# RATE_LIMIT_AUTH_PERMIT=30
# RATE_LIMIT_WRITE_PERMIT=60
