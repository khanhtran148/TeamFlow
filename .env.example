# TeamFlow Development Environment
# Copy this file to .env and fill in values
# NEVER commit .env to version control

# PostgreSQL
POSTGRES_DB=teamflow
POSTGRES_USER=teamflow
POSTGRES_PASSWORD=changeme

# RabbitMQ
RABBITMQ_DEFAULT_USER=teamflow
RABBITMQ_DEFAULT_PASS=changeme

# JWT
JWT_ISSUER=TeamFlow
JWT_AUDIENCE=TeamFlow.Users
JWT_SECRET=changeme-minimum-32-characters-long-secret-key

# Connection Strings (used by API and Background Services)
CONNECTION_STRING=Host=postgres;Database=teamflow;Username=teamflow;Password=changeme
